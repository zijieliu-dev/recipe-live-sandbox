# Salesforce dev-org credentials for the live connector.
# Copy this to test_sandbox/.env and fill in. Do NOT commit .env.
#
# Dev orgs log in at login.salesforce.com (sandboxes use test.salesforce.com).
SF_LOGIN_URL=https://login.salesforce.com
SF_API_VERSION=v59.0

# From your Connected App (Setup -> App Manager -> New Connected App ->
# enable OAuth, scopes: "api", "refresh_token, offline_access"):
SF_CLIENT_ID=your_connected_app_consumer_key
SF_CLIENT_SECRET=your_connected_app_consumer_secret

# --- Pick ONE auth flow ---
# Flow A (simplest, headless): username + password + security token.
#   Security token is emailed when you reset it (Setup -> Reset My Security Token).
SF_USERNAME=you@example.com
SF_PASSWORD=your_password
SF_SECURITY_TOKEN=your_security_token

# Flow B (alternative): a refresh token obtained from an initial OAuth flow.
# If set, this takes precedence over the password flow above.
# SF_REFRESH_TOKEN=your_refresh_token


# =====================================================================
# Jira Cloud (live connector). Omit any of these three -> Jira stays mocked.
# API token: https://id.atlassian.com/manage-profile/security/api-tokens
# =====================================================================
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your_atlassian_api_token


# =====================================================================
# Slack (live connector). Omit SLACK_BOT_TOKEN -> Slack stays mocked.
# Bot token from your Slack app (OAuth & Permissions). Scopes the recipes use:
#   chat:write, users:read, users:read.email, files:write
# WARNING: writes are REAL — point the recipes at a TEST channel.
# =====================================================================
SLACK_BOT_TOKEN=xoxb-your-bot-token
# Optional user token for the legacy 'slack' provider:
# SLACK_USER_TOKEN=xoxp-your-user-token
# Signing secret (Slack app -> Basic Information) for the live interaction bridge
# (live/slack_bridge.py). Needed only to test block_kit_modals / dialogs live.
# SLACK_SIGNING_SECRET=your_slack_signing_secret
# Optional: redirect every recipe Slack post to this channel id so messages that
# carry foreign channel ids land somewhere you can see them. Create a channel,
# /invite the bot, and put its id here. Remove to fire as-is.
# SLACK_CHANNEL_OVERRIDE=C0XXXXXXXXX
